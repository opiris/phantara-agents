# Supabase (instancia de Phantara, schema 'agents')
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# Anthropic (para todos los agentes que usen Claude)
ANTHROPIC_API_KEY=sk-ant-...

# Telegram (1 bot, 1 chat para todos los agentes)
TELEGRAM_BOT_TOKEN=1234567890:ABC...
TELEGRAM_CHAT_ID=123456789

# Pinterest (solo pinterest-publisher)
PINTEREST_ACCESS_TOKEN=

# Reddit (solo reddit-scout)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_USER_AGENT=phantara-scout:v1.0 (by /u/tu_usuario)

# TikTok (solo comment-responder y viral-hunter, opcional inicio)
TIKTOK_ACCESS_TOKEN=

# Entorno
NODE_ENV=production
